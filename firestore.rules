rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =====================
    // USERS COLLECTION
    // =====================
    match /users/{userId} {
      // All authenticated users can read all users (needed for role-based access)
      allow read: if request.auth != null;
      
      // Users can update their own data
      allow update: if request.auth != null && request.auth.uid == userId;
      
      // Admin can manage all users
      allow create, update, delete: if request.auth != null 
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      
      // Allow creation of users with specific roles
      allow create: if request.auth != null 
        && request.resource.data.role in ['admin', 'doctor', 'receptionist', 'patient'];
    }
    
    // =====================
    // PATIENTS COLLECTION
    // =====================
    match /patients/{patientId} {
      // All authenticated users can read patients
      allow read: if request.auth != null;
      
      // Admin can manage all patients
      allow create, update, delete: if request.auth != null 
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      
      // Receptionist can create and update patients
      allow create, update: if request.auth != null 
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'receptionist';
      
      // Doctor can update their assigned patients
      allow update: if request.auth != null 
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'doctor'
        && resource.data.doctorId == request.auth.uid;
    }

    // =====================
    // APPOINTMENTS COLLECTION
    // =====================
    match /appointments/{appointmentId} {
      // All authenticated users can read appointments
      allow read: if request.auth != null;
      
      // Admin can manage all appointments
      allow create, update, delete: if request.auth != null 
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      
      // Receptionist can create and update appointments
      allow create, update: if request.auth != null 
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'receptionist';
      
      // Doctor can update their appointments
      allow update: if request.auth != null 
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'doctor'
        && resource.data.doctorId == request.auth.uid;
      
      // Patient can create their own appointments
      allow create: if request.auth != null 
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'patient'
        && request.resource.data.patientId == request.auth.uid;
    }

    // =====================
    // PRESCRIPTIONS COLLECTION
    // =====================
    match /prescriptions/{prescriptionId} {
      // All authenticated users can read prescriptions
      allow read: if request.auth != null;
      
      // Admin can manage all prescriptions
      allow create, update, delete: if request.auth != null 
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      
      // Doctor can create and update prescriptions
      allow create, update: if request.auth != null 
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'doctor';
    }

    // =====================
    // MEDICAL RECORDS COLLECTION
    // =====================
    match /medicalRecords/{recordId} {
      // All authenticated users can read medical records
      allow read: if request.auth != null;
      
      // Admin can manage all records
      allow create, update, delete: if request.auth != null 
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      
      // Doctor can create and update records
      allow create, update: if request.auth != null 
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'doctor';
    }

    // =====================
    // DEPARTMENTS COLLECTION
    // =====================
    match /departments/{departmentId} {
      // All authenticated users can read departments
      allow read: if request.auth != null;
      
      // Admin can manage departments
      allow create, update, delete: if request.auth != null 
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // =====================
    // NOTIFICATIONS COLLECTION
    // =====================
    match /notifications/{notificationId} {
      // Users can read their own notifications
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      
      // Admin can read all notifications
      allow read: if request.auth != null 
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      
      // System can create notifications (any authenticated user for now)
      allow create: if request.auth != null;
      
      // Users can update their own notifications (mark as read)
      allow update: if request.auth != null && request.auth.uid == resource.data.userId;
    }
  }
}
